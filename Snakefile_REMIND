from pathlib import Path
import yaml
from os.path import normpath, exists, join
from shutil import copyfile, move, rmtree
from dotenv import load_dotenv
from snakemake.utils import min_version

load_dotenv()

min_version("8.11")

from scripts._helpers import (
    get_rdir,
    get_scenarios,
    get_shadow,
    path_provider,
    script_path_provider,
)
from scripts.lib.validation.config import validate_config

configfile: "config/config.default.yaml"
configfile: "config/config.remind.yaml"
configfile: "config/plotting.default.yaml"

validate_config(config)

run = config["run"]
#scenarios = get_scenarios(run)
# RDIR is used for running PyPSA-Eur at different regional resolutions
RDIR = get_rdir(run)
shadow_config = get_shadow(run)

shared_resources = run["shared_resources"]["policy"]
exclude_from_shared = run["shared_resources"]["exclude"]
logs = path_provider("logs/", RDIR, shared_resources, exclude_from_shared)
benchmarks = path_provider("benchmarks/", RDIR, shared_resources, exclude_from_shared)
resources = path_provider("resources/", RDIR, shared_resources, exclude_from_shared)
scripts = script_path_provider(Path(workflow.snakefile).parent)

# The following new wildcards are introduced for the coupling:
# * {scen_REMIND}: REMIND scenario name
# * {year_REMIND}: REMIND year
# * {iter_REMIND}: REMIND iteration

# REMIND coupling specific directories
# Structure, e.g.: resources/{scen_REMIND}/i{iter_REMIND}/y{year_REMIND}/
# SDIR = REMIND scenario directory (distinct from RDIR which is the PyPSA run-name dir set above)
SDIR = "{scen_REMIND}/"
IDIR = "i{iter_REMIND}/"

LOGS = "logs/"
SCENARIO_LOGS = LOGS + SDIR
ITERATION_LOGS = SCENARIO_LOGS + IDIR

BENCHMARKS = "benchmarks/"
SCENARIO_BENCHMARKS = BENCHMARKS + SDIR
ITERATION_BENCHMARKS = SCENARIO_BENCHMARKS + IDIR

RESOURCES = "resources/" + (
    "" if shared_resources else SDIR
)
SCENARIO_RESOURCES = "resources/" + SDIR
ITERATION_RESOURCES = SCENARIO_RESOURCES + IDIR

RESULTS = "results/"
SCENARIO_RESULTS = RESULTS + SDIR
ITERATION_RESULTS = SCENARIO_RESULTS + IDIR

# Rules that are run locally, not via a SLURM job
localrules:
    download_and_prepare_REMIND,
    retrieve_ssp_data,
    cluster_network,  # No SLURM b/c of Gurobi license check and small problem size
    solve_all_networks_REMIND,
    export_to_REMIND

wildcard_constraints:
    clusters="[0-9]+(m|c)?|all|adm",
    opts=r"[-+a-zA-Z0-9\.]*",
    sector_opts=r"[-+a-zA-Z0-9\.\s]*",
    planning_horizons=r"[0-9]{4}",
    year_REMIND="2[01][0-9][05]",
    scen_REMIND=".*",
    iter_REMIND="[0-9]+",


include: "rules/common.smk"


# Data constants
OSM_DATASET = dataset_version("osm")


include: "rules/retrieve.smk"

# All retrieve_* rules use the storage plugin: the HTTP download happens in the
# main process (login node), and the rule body just copies from cache to output.
# Mark them local to avoid submitting trivial copy jobs to SLURM.
workflow.localrules(*(
    r.name for r in workflow.rules
    if r.name.startswith("retrieve_")
))

include: "rules/build_electricity.smk"
include: "rules/build_sector.smk"


# Specific REMIND coupling rules
include: "rules/REMIND_coupling.smk"

